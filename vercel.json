{
    "redirects": [
        {
            "source": "https://www.soniyapatangemakeups.in/(.*)",
            "destination": "https://soniyapatangemakeups.in/$1",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/"
        }
    ],
    "crons": [
        {
            "path": "/api/ping",
            "schedule": "0 0 */5 * *"
        }
    ]
}